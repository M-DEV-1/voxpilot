    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/dotenv": "^8.2.3",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
